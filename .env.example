# Asclepius Configuration
# Copy this file to .env and adjust values

# Path on the HOST where Asclepius stores all data (vault files, database, config)
# This is mounted into the container at /data
ASCLEPIUS_DATA_PATH=./data

# Port to expose the web UI on
ASCLEPIUS_PORT=8070

# Secret key for session signing (change this!)
SECRET_KEY=change-me-in-production

# LLM API keys (set the one you use)
ANTHROPIC_API_KEY=
GOOGLE_VISION_KEY=
