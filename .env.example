# Asclepius configuration
# Copy this file to .env and adjust values.

# ── Paths ─────────────────────────────────────────────────────────
# Host path for the medical documents vault (mounted at /data/vault).
ASCLEPIUS_VAULT_PATH=./vault
# Host path for database + config (mounted at /data/config).
ASCLEPIUS_DATA_PATH=./data

# ── Network ───────────────────────────────────────────────────────
# Port the container exposes to the host.
ASCLEPIUS_PORT=8070

# "development" disables strict secret / cookie checks so you can run
# the app over plain HTTP on localhost. Set to "production" when
# deploying (and put HTTPS in front of it).
ASCLEPIUS_ENV=production

# CORS is only used in development (Vite dev server on another port).
# Comma-separated list of allowed origins — ignored in production.
#ASCLEPIUS_CORS_ORIGINS=http://localhost:5173

# ── Security ──────────────────────────────────────────────────────
# REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app will refuse to start in production mode with the placeholder.
SECRET_KEY=REPLACE_ME_WITH_A_RANDOM_48_CHAR_STRING

# Secure cookies require HTTPS. Set to 0 only for plain-HTTP local dev.
ASCLEPIUS_COOKIE_SECURE=1

# ── External providers (optional) ─────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_VISION_KEY=
